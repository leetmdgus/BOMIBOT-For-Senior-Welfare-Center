# ── 로컬 개발 (기본값으로 CORS localhost + Vercel/bomi regex 활성) ──
APP_ENV=development

DATABASE_URL=sqlite:///./bomi.db
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 추가 프론트 Origin (쉼표 구분). 비워도 development는 localhost:3000 등 자동 허용
# CORS_ORIGINS=http://localhost:3000

# Exact Origin 외 패턴 (비우면 *.vercel.app + *.bomi.ai.kr 자동, development/production 공통)
# CORS_ORIGIN_REGEX=
CORS_ALLOW_VERCEL_REGEX=true
CORS_ALLOW_BOMI_REGEX=true

AUTO_CREATE_TABLES=true
RUN_SEED_ON_STARTUP=false
SEED_MISSING_JSON_ON_STARTUP=true

# 업로드 파일 실제 저장 경로 (region_id 하위)
FILES_STORAGE_DIR=storage/uploads

# CS 티켓 메일 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CS_EMAIL_TO=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
GEMINI_MODEL=gemini-2.0-flash
# RAG_API_URL=
# RAG_TOP_K=8

# Google Calendar 연동 (대시보드 일정) — Google Cloud Console OAuth 클라이언트
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8020/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:3000
