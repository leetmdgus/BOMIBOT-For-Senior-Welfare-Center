# ── api-workspace.bomi.ai.kr 프로덕션 (docker compose prod용) ──
# cp .env.docker.example .env 후 아래 값으로 덮어쓰기
APP_ENV=production

POSTGRES_USER=bomibot
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=bomibot
# compose prod: DB 포트 외부 미노출

SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Vercel Production 커스텀 도메인 등 Exact Origin (쉼표 구분)
# CORS_ORIGINS=https://your-app.vercel.app,https://workspace.bomi.ai.kr

# Preview: *.vercel.app / 프론트: *.bomi.ai.kr (기본 true, 끄려면 false)
CORS_ALLOW_VERCEL_REGEX=true
CORS_ALLOW_BOMI_REGEX=true
# 전체 regex 직접 지정 시 위 플래그보다 우선
# CORS_ORIGIN_REGEX=https://(.*\.vercel\.app|workspace\.bomi\.ai\.kr)

TRUSTED_HOSTS=api-workspace.bomi.ai.kr,localhost,127.0.0.1

AUTO_CREATE_TABLES=false
RUN_ALEMBIC_ON_STARTUP=true
RUN_SEED_ON_STARTUP=false
SEED_MISSING_JSON_ON_STARTUP=false

# CS 티켓 (FastAPI /api/v1/chat/cs-ticket)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CS_EMAIL_TO=

# docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# docker compose exec api python scripts/seed.py --force   # 최초 1회 (또는 --missing-json)
# docker compose exec api alembic upgrade head

GEMINI_API_KEY=
GEMINI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
GEMINI_MODEL=gemini-2.0-flash

