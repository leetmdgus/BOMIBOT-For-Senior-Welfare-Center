# docker compose env (copy to backend/.env)
POSTGRES_USER=bomibot
# 로컬 Docker 기본값(compose 기본과 동일). 변경 후에는: docker compose down -v && up
POSTGRES_PASSWORD=bomibot
POSTGRES_DB=bomibot
# 호스트 포트 (컨테이너 내부는 항상 5432). 기존 postgres가 5432 쓰면 5433 유지
POSTGRES_PORT=5433

API_PORT=9001
APP_ENV=development
SECRET_KEY=change-me

RUN_ALEMBIC_ON_STARTUP=false
RUN_SEED_ON_STARTUP=true
SEED_MISSING_JSON_ON_STARTUP=true
AUTO_CREATE_TABLES=true

CORS_ALLOW_VERCEL_REGEX=true
CORS_ALLOW_BOMI_REGEX=true
# CORS_ORIGINS=https://your-vercel-domain.vercel.app

# CS 티켓 메일 (선택 — Gmail 앱 비밀번호)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CS_EMAIL_TO=

# 데이터 챗봇 (OpenAI 호환 Gemini 게이트웨이) — /api/v1/chat/assistant
GEMINI_API_KEY=
GEMINI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
GEMINI_MODEL=gemini-2.0-flash
# RAG_API_URL=
# RAG_API_KEY=
# RAG_TOP_K=8

# cd backend
# cp .env.docker.example .env    # POSTGRES_PASSWORD, SECRET_KEY 수정
# docker compose up -d --build --remove-orphans
#
# ── 프로덕션 (api-workspace.bomi.ai.kr) 추가 설정 ──
# APP_ENV=production
# SECRET_KEY=<generate-secrets.ps1>
# CORS_ORIGINS=https://your-app.vercel.app
# TRUSTED_HOSTS=api-workspace.bomi.ai.kr
# RUN_ALEMBIC_ON_STARTUP=true
# RUN_SEED_ON_STARTUP=false
# AUTO_CREATE_TABLES=false
# 배포: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
