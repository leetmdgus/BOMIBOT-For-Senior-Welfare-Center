# 데이터 챗봇 (OpenAI 호환 Gemini 게이트웨이)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
GEMINI_MODEL=gemini-2.0-flash

# CS 메일 접수 (Gmail 예시 — 앱 비밀번호 필요, 일반 비밀번호 불가)
SMTP_SERVICE=gmail
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
# 발신 표시 (선택, 없으면 SMTP_USER)
# SMTP_FROM=your@gmail.com
# 수신 CS 담당 메일
CS_EMAIL_TO=bomi20260413@gmail.com

# RAG (선택) — 외부 RAG API가 있으면 POST { question, top_k } 로 연동. 없으면 로컬 mock 코퍼스 검색
# RAG_API_URL=https://your-rag-service.example.com/query
# RAG_API_KEY=
# RAG_TOP_K=8

# ── API 모드 (택 1) ──
# A) Mock only (백엔드 불필요)
NEXT_PUBLIC_USE_MOCK_API=true

# B) FastAPI 직연동 (권장 — Vercel/로컬)
# NEXT_PUBLIC_USE_MOCK_API=false
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9001
# Google 캘린더 연동(선택): backend/.env 에 GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI, FRONTEND_URL
# 실시간 협업 WebSocket (기본 OFF — 사용 시에만 true)
# NEXT_PUBLIC_COLLABORATION_ENABLED=true
# NEXT_PUBLIC_WS_BASE_URL=ws://localhost:9001
# 프로덕션: https://api-workspace.bomi.ai.kr

# C) 상대 /api/* → Next catch-all → FastAPI 프록시 (레거시)
# NEXT_PUBLIC_USE_MOCK_API=false
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9001
# (브라우저가 /api/dashboard 를 쓰는 경우에만; 보통 B와 동일 URL)
