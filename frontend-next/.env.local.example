# cp .env.local.example .env.local
# 프론트 dev/start 포트: 9000 (package.json scripts)

# ── 로컬 FastAPI (권장: Next 프록시 → CORS·Workbox 회피) ──
NEXT_PUBLIC_USE_API_PROXY=true
# 서버 프록시는 127.0.0.1 권장 (Windows localhost IPv6 이슈 방지)
# Docker: 9001 | 로컬 uvicorn이 다른 포트면 그 포트로 (netstat로 확인)
NEXT_PUBLIC_API_PROXY_URL=http://127.0.0.1:9001
API_PROXY_URL=http://127.0.0.1:9001
NEXT_PUBLIC_USE_MOCK_API=false

# 실시간 협업 WebSocket — `docker compose up -d --build api` 후 true
NEXT_PUBLIC_COLLABORATION_ENABLED=false
# NEXT_PUBLIC_WS_BASE_URL=ws://localhost:9001

# 브라우저 직연동( CORS·ERR_FAILED 유발 ) — 사용하지 마세요
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:9001

# ── Mock only (백엔드 없이 UI) ──
# NEXT_PUBLIC_USE_MOCK_API=true
