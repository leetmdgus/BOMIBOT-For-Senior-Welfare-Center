# 풀스택 docker compose 용 — 루트에 .env 로 복사
#   cp .env.docker.example .env
# 루트 docker-compose.yml 이 이 값들을 읽어 web + api + db 에 주입.

# ── 포트 (호스트) ──
WEB_PORT=9000
API_PORT=9001
POSTGRES_PORT=5433          # 컨테이너 내부는 항상 5432. 5432 충돌 시 5433 유지

# ── PostgreSQL ──
POSTGRES_USER=bomibot
POSTGRES_PASSWORD=bomibot   # ⚠️ 프로덕션은 강한 값으로. 변경 후엔 down -v 후 up
POSTGRES_DB=bomibot

# ── API (FastAPI) ──
APP_ENV=development         # 프로덕션은 prod 오버레이가 production 으로 덮음
SECRET_KEY=change-me        # ⚠️ 프로덕션은 강한 random (backend/scripts/generate-secrets.ps1)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — 프록시 모드(웹·API 동일 컴포즈)면 보통 불필요. 프론트를 별도 도메인에 둘 때만.
# CORS_ORIGINS=https://workspace.bomi.ai.kr
CORS_ALLOW_VERCEL_REGEX=true
CORS_ALLOW_BOMI_REGEX=true
TRUSTED_HOSTS=api-workspace.bomi.ai.kr,localhost,127.0.0.1

# 시드/마이그레이션 (로컬 기본값; 프로덕션 오버레이가 조정)
AUTO_CREATE_TABLES=true
RUN_ALEMBIC_ON_STARTUP=true
RUN_SEED_ON_STARTUP=true
SEED_MISSING_JSON_ON_STARTUP=true

# ── web(Next) 서버 → FastAPI 프록시 대상 (내부망 서비스명) ──
API_PROXY_URL=http://api:9001

# ── 실시간 협업 WebSocket (선택, 빌드 타임) ──
NEXT_PUBLIC_COLLABORATION_ENABLED=false

# ── 데이터 챗봇 (OpenAI 호환 Gemini 게이트웨이) — api·web 공용 ──
GEMINI_API_KEY=
GEMINI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
GEMINI_MODEL=gemini-2.0-flash
# RAG_API_URL=
# RAG_API_KEY=
# RAG_TOP_K=8

# ── CS 티켓 메일 (선택 — Gmail 앱 비밀번호) ──
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CS_EMAIL_TO=
